{
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npx nodemon index.js",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && tsc && vite build",
    "preview": "cd client && vite preview"
  }
}
